# ===================================
# HelpingYou - Environment Variables
# ===================================
# Copy this file to .env and fill in your actual values

# ===================================
# NODE ENVIRONMENT
# ===================================
NODE_ENV=development

# ===================================
# DATABASE - PostgreSQL
# ===================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=helpingyou
DB_PASSWORD=password
DB_NAME=helpingyou_dev
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===================================
# REDIS CACHE
# ===================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ===================================
# MONGODB
# ===================================
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB=helpingyou_dev
MONGO_PORT=27017
MONGO_URL=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb:${MONGO_PORT}/${MONGO_DB}?authSource=admin

# ===================================
# ELASTICSEARCH
# ===================================
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://${ELASTICSEARCH_HOST}:${ELASTICSEARCH_PORT}

# ===================================
# BACKEND API
# ===================================
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000
API_VERSION=v1

# ===================================
# FRONTEND WEB
# ===================================
WEB_PORT=5173
WEB_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000
VITE_WEBSOCKET_URL=ws://localhost:3000

# ===================================
# AUTHENTICATION & SECURITY
# ===================================
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=10

# ===================================
# OAuth / Third-party
# ===================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3000/auth/microsoft/callback

# ===================================
# EMAIL CONFIGURATION
# ===================================
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@helpingyou.local
MAIL_FROM_NAME=HelpingYou
MAIL_SECURE=false

# For production use SMTP provider (SendGrid, AWS SES, etc.)
# SENDGRID_API_KEY=
# AWS_SES_REGION=us-east-1

# ===================================
# AWS S3 / File Storage
# ===================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=helpingyou-dev
AWS_S3_URL=https://${AWS_S3_BUCKET}.s3.${AWS_REGION}.amazonaws.com

# ===================================
# FILE UPLOAD
# ===================================
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf,text/plain
UPLOAD_DIR=./uploads

# ===================================
# LOGGING
# ===================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# ===================================
# PAGINATION
# ===================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ===================================
# RATE LIMITING
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# CORS & SECURITY
# ===================================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ===================================
# SWAGGER / API DOCUMENTATION
# ===================================
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

# ===================================
# MONITORING & OBSERVABILITY
# ===================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_ENABLED=false

# New Relic
NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=

# DataDog
DATADOG_ENABLED=false
DATADOG_API_KEY=

# ===================================
# FEATURE FLAGS
# ===================================
FEATURE_DARK_MODE=true
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_NOTIFICATIONS=true
FEATURE_ANALYTICS=true
FEATURE_EXPORT_DATA=true

# ===================================
# MOBILE APP
# ===================================
MOBILE_API_URL=http://192.168.1.100:3000
MOBILE_WEBSOCKET_URL=ws://192.168.1.100:3000

# ===================================
# DEVELOPMENT TOOLS
# ===================================
DEBUG=helpingyou:*
INSPECTOR_ENABLED=false
INSPECTOR_PORT=9229

# ===================================
# PGADMIN (Development)
# ===================================
PGADMIN_EMAIL=admin@helpingyou.local
PGADMIN_PASSWORD=password
PGADMIN_PORT=5050

# ===================================
# ADMINER (Development)
# ===================================
ADMINER_PORT=8080

# ===================================
# DOCKER
# ===================================
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ===================================
# CRON JOBS
# ===================================
CRON_ENABLED=true
CRON_CLEANUP_OLD_LOGS=0 2 * * *
CRON_SEND_DIGEST_EMAIL=0 9 * * MON
CRON_GENERATE_REPORTS=0 23 * * SUN

# ===================================
# API KEYS & INTEGRATIONS
# ===================================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ===================================
# TESTING
# ===================================
TEST_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/helpingyou_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_TIMEOUT=30000
