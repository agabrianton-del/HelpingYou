{
  "name": "helpingyou",
  "version": "0.1.0",
  "description": "Plataforma integral de gestión de tareas y productividad con IA integrada",
  "author": "HelpingYou Enterprise",
  "license": "Apache-2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/agabrianton-del/HelpingYou.git"
  },
  "homepage": "https://helpingyou.dev",
  "bugs": {
    "url": "https://github.com/agabrianton-del/HelpingYou/issues"
  },
  "keywords": [
    "productivity",
    "task-management",
    "ai",
    "collaboration",
    "helpingyou"
  ],
  "workspaces": [
    "packages/backend",
    "packages/web",
    "packages/mobile",
    "packages/shared",
    "packages/cli"
  ],
  "scripts": {
    "dev": "lerna run dev --parallel",
    "dev:backend": "lerna run dev --scope=@helpingyou/backend",
    "dev:web": "lerna run dev --scope=@helpingyou/web",
    "dev:mobile": "lerna run dev --scope=@helpingyou/mobile",
    "build": "lerna run build --parallel",
    "build:backend": "lerna run build --scope=@helpingyou/backend",
    "build:web": "lerna run build --scope=@helpingyou/web",
    "build:mobile": "lerna run build --scope=@helpingyou/mobile",
    "test": "lerna run test --parallel",
    "test:watch": "lerna run test:watch --parallel",
    "test:coverage": "lerna run test:coverage --parallel",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "clean": "lerna clean --yes && rm -rf node_modules dist coverage",
    "clean:dist": "lerna run clean --parallel",
    "clean:cache": "rm -rf node_modules/.cache",
    "type-check": "lerna run type-check --parallel",
    "version": "lerna version",
    "publish": "lerna publish",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "verify": "npm run lint && npm run type-check && npm run test",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose up -d --build",
    "monorepo:info": "lerna list --all",
    "monorepo:bootstrap": "lerna bootstrap",
    "monorepo:clean": "lerna clean --yes"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lerna": "^7.4.2",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "yarn": ">=3.6.0"
  },
  "volta": {
    "node": "22.0.0",
    "npm": "10.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
